{
  "name": "acbl-live-fetch",
  "version": "0.2.0",
  "description": "Browser extension that fetches bridge game data from supported sites and hands it to bridge-classroom.com for analysis.",
  "type": "module",
  "license": "Unlicense",
  "scripts": {
    "build": "vite build",
    "build:chrome": "BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "build:edge": "BROWSER=edge vite build",
    "build:safari": "BROWSER=safari vite build",
    "build:all": "npm run build:chrome && npm run build:firefox && npm run build:edge && npm run build:safari",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "linkedom": "^0.18.12",
    "webextension-polyfill": "^0.12.0"
  }
}
