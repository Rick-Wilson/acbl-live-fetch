{
  "manifest_version": 3,
  "name": "ACBL Live Fetch",
  "version": "0.2.2",
  "description": "One-click extraction of bridge results from supported sites for analysis at bridge-classroom.org.",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://live.acbl.org/*",
        "https://my.acbl.org/*",
        "https://webutil.bridgebase.com/v2/tview.php*",
        "https://www.bridgebase.com/myhands/hands.php*"
      ],
      "js": ["src/ui/sourceContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.bridgebase.com/v3/*"],
      "js": ["src/ui/bboLobbyContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://game-analysis.bridge-classroom.org/analyze*",
        "https://game-analysis.bridge-classroom.com/analyze*",
        "http://localhost:3001/analyze*"
      ],
      "js": ["src/ui/analyzerContent.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://live.acbl.org/*",
    "https://my.acbl.org/*",
    "https://game-analysis.bridge-classroom.org/*",
    "https://game-analysis.bridge-classroom.com/*",
    "http://localhost:3001/*",
    "https://webutil.bridgebase.com/*",
    "https://www.bridgebase.com/*"
  ]
}
