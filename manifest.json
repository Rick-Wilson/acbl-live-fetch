{
  "manifest_version": 3,
  "name": "ACBL Live Fetch",
  "version": "0.2.2",
  "description": "One-click extraction of bridge results from supported sites for analysis at bridge-classroom.com.",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://live.acbl.org/*", "https://my.acbl.org/*"],
      "js": ["src/ui/sourceContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://club-game-analysis.bridge-classroom.com/analyze*"],
      "js": ["src/ui/analyzerContent.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://live.acbl.org/*",
    "https://my.acbl.org/*",
    "https://club-game-analysis.bridge-classroom.com/*"
  ]
}
